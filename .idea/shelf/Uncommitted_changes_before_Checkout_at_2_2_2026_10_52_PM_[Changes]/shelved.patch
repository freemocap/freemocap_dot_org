ont-size: 0.9rem; }\r\n            .filter-group { flex-direction: column; align-items: flex-start; gap: 0.25rem; }\r\n            .filter-hint { font-size: 0.65rem; }\r\n            .data-note { font-size: 0.7rem; padding: 0.75rem; margin: 0.5rem; }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"header\">\r\n        <h1>FreeMoCap Usage Dashboard</h1>\r\n        <p id=\"generated-date\">Loading...</p>\r\n    </div>\r\n\r\n\r\n\r\n    <div class=\"stats-grid\">\r\n        <div class=\"stat-card\">\r\n            <div class=\"stat-value\" id=\"stat-total-records\">-</div>\r\n            <div class=\"stat-label\">Total Pings</div>\r\n        </div>\r\n        <div class=\"stat-card\">\r\n            <div class=\"stat-value\" id=\"stat-unique-users\">-</div>\r\n            <div class=\"stat-label\">Total Users</div>\r\n        </div>\r\n        <div class=\"stat-card\">\r\n            <div class=\"stat-value\" id=\"stat-countries\">-</div>\r\n            <div class=\"stat-label\">Countries</div>\r\n        </div>\r\n        <div class=\"stat-card\">\r\n            <div class=\"stat-value\" id=\"stat-repeat-rate\">-</div>\r\n            <div class=\"stat-label\">Came Back</div>\r\n        </div>\r\n        <div class=\"stat-card\">\r\n            <div class=\"stat-value\" id=\"stat-mean-per-user\">-</div>\r\n            <div class=\"stat-label\">Avg. per User</div>\r\n        </div>\r\n        <div class=\"stat-card\">\r\n            <div class=\"stat-value\" id=\"stat-median-per-user\">-</div>\r\n            <div class=\"stat-label\">Typical User</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"map-container\" style=\"position: relative;\">\r\n        <div class=\"map-controls\">\r\n            <div class=\"control-section\">\r\n                <div class=\"control-heading\">Layers</div>\r\n                <label><input type=\"checkbox\" id=\"toggle-heatmap\" checked> Heatmap</label>\r\n                <label><input type=\"checkbox\" id=\"toggle-markers\" checked> Markers</label>\r\n                <label><input type=\"checkbox\" id=\"toggle-contours\" checked> Contours</label>\r\n            </div>\r\n\r\n            <div class=\"control-section\">\r\n                <div class=\"control-heading\">Basemap</div>\r\n                <select id=\"basemap-select\" style=\"width: 100%;\">\r\n                    <option value=\"osm\">OpenStreetMap</option>\r\n                    <option value=\"positron\">Light (Positron)</option>\r\n                    <option value=\"darkmatter\">Dark</option>\r\n                    <option value=\"toner\">B&W Borders</option>\r\n                    <option value=\"none\">None</option>\r\n                </select>\r\n            </div>\r\n\r\n            <div class=\"control-section\">\r\n                <div class=\"control-heading\">Markers</div>\r\n                <label><input type=\"checkbox\" id=\"toggle-scale-markers\"> Scale by count</label>\r\n                <div class=\"control-row\">\r\n                    <span>Fill:</span>\r\n                    <input type=\"color\" id=\"marker-color\" value=\"#000000\" class=\"color-picker\">\r\n                    <label class=\"inline-label\"><input type=\"checkbox\" id=\"marker-random-fill\"> Random</label>\r\n                </div>\r\n                <div class=\"control-row\">\r\n                    <label class=\"inline-label\"><input type=\"checkbox\" id=\"marker-outline\"> Outline:</label>\r\n                    <input type=\"color\" id=\"marker-outline-color\" value=\"#ffffff\" class=\"color-picker\">\r\n                    <label class=\"inline-label\"><input type=\"checkbox\" id=\"marker-random-outline\"> Random</label>\r\n                </div>\r\n                <div class=\"control-row\">\r\n                    <span>Jitter (km):</span>\r\n                    <input type=\"number\" id=\"marker-jitter\" min=\"1\" max=\"1000\" value=\"10\" class=\"num-input\">\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"control-section\">\r\n                <div class=\"control-heading\">Heatmap</div>\r\n                <div class=\"control-row\">\r\n                    <span>Colormap:</span>\r\n                    <select id=\"colormap-select\" style=\"flex: 1;\">\r\n                        <option value=\"plasma\">Plasma</option>\r\n                        <option value=\"viridis\">Viridis</option>\r\n                        <option value=\"inferno\">Inferno</option>\r\n                        <option value=\"magma\">Magma</option>\r\n                        <option value=\"thermal\">Thermal (Jet)</option>\r\n                        <option value=\"cool\">Cool</option>\r\n                        <option value=\"hot\">Hot</option>\r\n                    </select>\r\n                </div>\r\n                <div class=\"control-row\">\r\n                    <span>Opacity:</span>\r\n                    <input type=\"range\" id=\"heatmap-opacity\" min=\"0.1\" max=\"1\" step=\"0.1\" value=\"0.6\" style=\"flex: 1;\">\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"control-section\">\r\n                <div class=\"control-heading\">Contours</div>\r\n                <div class=\"control-row\">\r\n                    <span>Color:</span>\r\n                    <input type=\"color\" id=\"contour-color\" value=\"#eeeeee\" class=\"color-picker\">\r\n                </div>\r\n                <div class=\"control-row\">\r\n                    <span>Kernel (px):</span>\r\n                    <input type=\"number\" id=\"contour-kernel\" min=\"1\" max=\"500\" value=\"10\" class=\"num-input\">\r\n                </div>\r\n                <div class=\"control-row\">\r\n                    <span>Min %:</span>\r\n                    <input type=\"number\" id=\"contour-min\" min=\"0\" max=\"100\" value=\"1\" class=\"num-input\">\r\n                </div>\r\n                <div class=\"control-row\">\r\n                    <span>Max %:</span>\r\n                    <input type=\"number\" id=\"contour-max\" min=\"0\" max=\"100\" value=\"80\" class=\"num-input\">\r\n                </div>\r\n                <div class=\"control-row\">\r\n                    <span>Levels:</span>\r\n                    <input type=\"number\" id=\"contour-levels\" min=\"1\" max=\"20\" value=\"10\" class=\"num-input\">\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div id=\"map\"></div>\r\n    </div>\r\n    <div class=\"data-note\">\r\n        <strong>What is this data?</strong> Each point on the map is someone who used FreeMoCap and chose to share anonymous usage data.\r\n        We use their IP address to estimate their location (via <a href=\"http://ip-api.com\" target=\"_blank\">ip-api.com</a>).\r\n        <br><br>\r\n        <strong>Important notes:</strong> This undercounts actual users—people who turned off sharing aren't included, and multiple people at universities or offices often share one IP address.\r\n        VPNs can also make locations inaccurate.\r\n    </div>\r\n\r\n    <!-- Row 1: Users - Total over time + Daily growth -->\r\n    <div class=\"charts-grid charts-grid-2col\">\r\n        <div class=\"section\">\r\n            <h2>Total Users Over Time</h2>\r\n            <p class=\"chart-subtitle\">Running total of all users who have used FreeMoCap</p>\r\n            <div id=\"chart-cumulative-users\" class=\"chart\"></div>\r\n        </div>\r\n        <div class=\"section\">\r\n            <h2>New Users Each Day</h2>\r\n            <p class=\"chart-subtitle\">Dots = daily, bands = weekly (dark) and monthly (light) averages ± 1 SD</p>\r\n            <div id=\"chart-daily-users\" class=\"chart\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Row 2: Activity - Total over time + Daily -->\r\n    <div class=\"charts-grid charts-grid-2col\">\r\n        <div class=\"section\">\r\n            <h2>Total Activity Over Time</h2>\r\n            <p class=\"chart-subtitle\">Running total of all pings from all users</p>\r\n            <div id=\"chart-cumulative-pings\" class=\"chart\"></div>\r\n        </div>\r\n        <div class=\"section\">\r\n            <h2>Daily Activity</h2>\r\n            <p class=\"chart-subtitle\">Dots = daily, bands = weekly (dark) and monthly (light) averages ± 1 SD</p>\r\n            <div id=\"chart-daily-pings\" class=\"chart\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Row 3: How often do users return + User types -->\r\n    <div class=\"charts-grid charts-grid-engagement\">\r\n        <div class=\"section\">\r\n            <h2>How Often Do Users Return?</h2>\r\n            <p class=\"chart-subtitle\">Each dot = users who checked in X times. Colors match the categories on the right.</p>\r\n            <div id=\"chart-pings-distribution\" class=\"chart\"></div>\r\n        </div>\r\n        <div class=\"section\">\r\n            <h2>Types of Users</h2>\r\n            <p class=\"chart-subtitle\">Users grouped by how often they check in</p>\r\n            <div id=\"chart-engagement-tiers\" class=\"chart\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Row 4: When are users active -->\r\n    <div class=\"charts-grid charts-grid-2col\">\r\n        <div class=\"section\">\r\n            <h2>What Time of Day?</h2>\r\n            <p class=\"chart-subtitle\">Activity by hour (in UTC/GMT timezone)</p>\r\n            <div id=\"chart-hourly\" class=\"chart\"></div>\r\n        </div>\r\n        <div class=\"section\">\r\n            <h2>Which Days Are Busiest?</h2>\r\n            <p class=\"chart-subtitle\">Total activity by day of the week</p>\r\n            <div id=\"chart-day-of-week\" class=\"chart\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"country-controls\" style=\"padding: 1rem;\">\r\n        <div class=\"controls-inner\">\r\n            <div class=\"control-row\">\r\n                <div class=\"filter-group\">\r\n                    <label for=\"country-search\">\uD83D\uDD0D Find a country:</label>\r\n                    <input type=\"text\" id=\"country-search\" placeholder=\"Type country name...\" autocomplete=\"off\">\r\n                </div>\r\n                <div class=\"filter-group\">\r\n                    <label for=\"min-population\">Min population:</label>\r\n                    <input type=\"number\" id=\"min-population\" value=\"0\" min=\"0\" max=\"100\" step=\"0.5\">\r\n                    <span class=\"filter-hint\">million people (try 0.5)</span>\r\n                </div>\r\n                <div class=\"filter-group\">\r\n                    <label for=\"min-area\">Min area:</label>\r\n                    <input type=\"number\" id=\"min-area\" value=\"0\" min=\"0\" max=\"10000\" step=\"1\">\r\n                    <span class=\"filter-hint\">100 km² (try 12)</span>\r\n                </div>\r\n                <div class=\"filter-group\">\r\n                    <button id=\"reset-filters\" type=\"button\">Reset</button>\r\n                </div>\r\n            </div>\r\n            <div class=\"highlight-summary\" id=\"highlight-summary\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"charts-grid charts-grid-3col country-charts-row\">\r\n        <div class=\"section\">\r\n            <h2>Where Are Our Users? <span id=\"countries-count-absolute\" class=\"count-badge\"></span></h2>\r\n            <p class=\"chart-subtitle\">Total users in each country</p>\r\n            <div id=\"chart-countries\" class=\"chart\"></div>\r\n        </div>\r\n        <div class=\"section\">\r\n            <h2>Users per Million People <span id=\"countries-count-percapita\" class=\"count-badge\"></span></h2>\r\n            <p class=\"chart-subtitle\" title=\"How likely are you to run into a FreeMoCap user at the store in a given country?\">Adjusts for country population size <span style=\"cursor:help; font-size:0.9em;\">ⓘ</span></p>\r\n            <div id=\"chart-countries-per-capita\" class=\"chart\"></div>\r\n        </div>\r\n        <div class=\"section\">\r\n            <h2>Users by Country Size <span id=\"countries-count-density\" class=\"count-badge\"></span></h2>\r\n            <p class=\"chart-subtitle\" title=\"If you throw a stick in a given country, how likely is it to hit a FreeMoCap user?\">Users per 100,000 km² of land <span style=\"cursor:help; font-size:0.9em;\">ⓘ</span></p>\r\n            <div id=\"chart-countries-density\" class=\"chart\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n        // Load data and initialize dashboard\r\n        async function initDashboard() {\r\n            try {\r\n                const response = await fetch('freemocap_dashboard_data.json');\r\n                if (!response.ok) {\r\n                    throw new Error(`Failed to load freemocap_dashboard_data.json: ${response.status} ${response.statusText}`);\r\n                }\r\n                const data = await response.json();\r\n                renderDashboard(data);\r\n            } catch (error) {\r\n                console.error('Failed to load dashboard data:', error);\r\n                document.getElementById('generated-date').textContent = 'Error loading data';\r\n                document.getElementById('generated-date').style.color = '#e53e3e';\r\n            }\r\n        }\r\n\r\n        function renderDashboard(data) {\r\n            const { stats, time_series: timeSeries, map_data: mapData, country_data: countryData, hourly_data: hourlyData, generated_at } = data;\r\n            const pingsDistribution = data.pings_distribution || [];\r\n\r\n            // Update header\r\n            const generatedDate = new Date(generated_at);\r\n            document.getElementById('generated-date').textContent = `Generated: ${generatedDate.toLocaleString()}`;\r\n\r\n            // Update stat cards\r\n            document.getElementById('stat-total-records').textContent = stats.total_records.toLocaleString();\r\n            document.getElementById('stat-unique-users').textContent = stats.unique_users.toLocaleString();\r\n            document.getElementById('stat-countries').textContent = stats.countries;\r\n            document.getElementById('stat-repeat-rate').textContent = `${stats.repeat_rate}%`;\r\n            document.getElementById('stat-mean-per-user').textContent = stats.mean_per_user;\r\n            document.getElementById('stat-median-per-user').textContent = stats.median_per_user;\r\n\r\n            // Initialize map\r\n            initMap(mapData);\r\n\r\n            // Initialize charts\r\n            initCharts(timeSeries, countryData, hourlyData, pingsDistribution);\r\n        }\r\n\r\n        let map, heatLayer, markersLayer, contourLayer;\r\n        let currentColormap = 'plasma';\r\n        let currentOpacity = 0.6;\r\n        let currentBasemap;\r\n        let globalMapData;\r\n\r\n        const basemaps = {};\r\n        const colormaps = {\r\n            plasma: {0.0: '#0d0887', 0.25: '#7e03a8', 0.5: '#cc4778', 0.75: '#f89540', 1: '#f0f921'},\r\n            viridis: {0.0: '#440154', 0.25: '#3b528b', 0.5: '#21918c', 0.75: '#5ec962', 1: '#fde725'},\r\n            inferno: {0.0: '#000004', 0.25: '#57106e', 0.5: '#bc3754', 0.75: '#f98e09', 1: '#fcffa4'},\r\n            magma: {0.0: '#000004', 0.25: '#51127c', 0.5: '#b73779', 0.75: '#fc8961', 1: '#fcfdbf'},\r\n            thermal: {0.4: 'blue', 0.6: 'lime', 0.8: 'yellow', 1: 'red'},\r\n            cool: {0.0: '#00ffff', 0.5: '#8080ff', 1: '#ff00ff'},\r\n            hot: {0.0: '#000000', 0.33: '#ff0000', 0.66: '#ffff00', 1: '#ffffff'}\r\n        };\r\n\r\n        function initMap(mapData) {\r\n            globalMapData = mapData;\r\n\r\n            map = L.map('map', {\r\n                maxBounds: [[-90, -180], [90, 180]],\r\n                maxBoundsViscosity: 1.0,\r\n                minZoom: 2\r\n            }).setView([20, 0], 2);\r\n\r\n            // Create custom panes to control layer ordering\r\n            // Lower z-index = rendered first (below)\r\n            map.createPane('markersPane');\r\n            map.getPane('markersPane').style.zIndex = 450;\r\n            \r\n            map.createPane('contoursPane');\r\n            map.getPane('contoursPane').style.zIndex = 500;\r\n\r\n            // Setup basemaps\r\n            basemaps.osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {\r\n                attribution: '&copy; OpenStreetMap contributors',\r\n                maxZoom: 18,\r\n                noWrap: true\r\n            });\r\n            basemaps.positron = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {\r\n                attribution: '&copy; OpenStreetMap contributors &copy; CARTO',\r\n                maxZoom: 19,\r\n                noWrap: true\r\n            });\r\n            basemaps.darkmatter = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {\r\n                attribution: '&copy; OpenStreetMap contributors &copy; CARTO',\r\n                maxZoom: 19,\r\n                noWrap: true\r\n            });\r\n            basemaps.toner = L.tileLayer('https://tiles.stadiamaps.com/tiles/stamen_toner_lite/{z}/{x}/{y}{r}.png', {\r\n                attribution: '&copy; Stamen Design &copy; OpenStreetMap contributors',\r\n                maxZoom: 18,\r\n                noWrap: true\r\n            });\r\n            basemaps.none = null;\r\n\r\n            currentBasemap = basemaps.osm;\r\n            currentBasemap.addTo(map);\r\n\r\n            // Heatmap layer\r\n            const heatData = mapData.map(d => [d.lat, d.lon, Math.min(d.count, 50)]);\r\n            heatLayer = L.heatLayer(heatData, {\r\n                radius: 20,\r\n                blur: 15,\r\n                maxZoom: 10,\r\n                gradient: colormaps[currentColormap]\r\n            });\r\n            heatLayer.addTo(map);\r\n            setTimeout(() => setHeatmapOpacity(currentOpacity), 100);\r\n\r\n            // Contour layer\r\n            contourLayer = L.layerGroup();\r\n\r\n            // Markers layer\r\n            markersLayer = L.layerGroup();\r\n            createMarkers();\r\n            markersLayer.addTo(map);\r\n\r\n            // Initial contour build\r\n            rebuildContours();\r\n            contourLayer.addTo(map);\r\n\r\n            // Event listeners\r\n            setupMapControls();\r\n\r\n            map.on('moveend', debouncedRebuildContours);\r\n            map.on('zoomend', debouncedRebuildContours);\r\n        }\r\n\r\n        function setHeatmapOpacity(opacity) {\r\n            const heatCanvas = document.querySelector('.leaflet-heatmap-layer');\r\n            if (heatCanvas) heatCanvas.style.opacity = opacity;\r\n        }\r\n\r\n        function rebuildHeatmap() {\r\n            const heatData = globalMapData.map(d => [d.lat, d.lon, Math.min(d.count, 50)]);\r\n            const wasVisible = map.hasLayer(heatLayer);\r\n            if (wasVisible) map.removeLayer(heatLayer);\r\n            heatLayer = L.heatLayer(heatData, {\r\n                radius: 20,\r\n                blur: 15,\r\n                maxZoom: 10,\r\n                gradient: colormaps[currentColormap]\r\n            });\r\n            if (wasVisible || document.getElementById('toggle-heatmap').checked) {\r\n                heatLayer.addTo(map);\r\n                setTimeout(() => setHeatmapOpacity(currentOpacity), 50);\r\n            }\r\n        }\r\n\r\n        function seededRandom(seed) {\r\n            const x = Math.sin(seed) * 10000;\r\n            return x - Math.floor(x);\r\n        }\r\n\r\n        function hashString(str) {\r\n            let hash = 0;\r\n            for (let i = 0; i < str.length; i++) {\r\n                hash = ((hash << 5) - hash) + str.charCodeAt(i);\r\n                hash = hash & hash;\r\n            }\r\n            return hash;\r\n        }\r\n\r\n        function randomColor(seed) {\r\n            const h = Math.floor(seededRandom(seed) * 360);\r\n            return `hsl(${h}, 70%, 50%)`;\r\n        }\r\n\r\n        function getJitteredPosition(d) {\r\n            const jitterKm = parseFloat(document.getElementById('marker-jitter').value) || 0;\r\n            const jitterDeg = jitterKm / 111.0;\r\n\r\n            let lat = d.lat;\r\n            let lon = d.lon;\r\n            if (jitterDeg > 0) {\r\n                const userIndexHash = hashString(String(d.user_index));\r\n                const angle = seededRandom(userIndexHash) * 2 * Math.PI;\r\n                const dist = seededRandom(userIndexHash + 1) * jitterDeg;\r\n                lat += dist * Math.cos(angle);\r\n                lon += dist * Math.sin(angle) / Math.cos(d.lat * Math.PI / 180);\r\n            }\r\n            return { lat, lon };\r\n        }\r\n\r\n        function rebuildContours() {\r\n            contourLayer.clearLayers();\r\n\r\n            const bounds = map.getBounds();\r\n            const size = map.getSize();\r\n\r\n            const contourColor = document.getElementById('contour-color').value;\r\n            const kernelPx = parseFloat(document.getElementById('contour-kernel').value) || 20;\r\n            const minPct = parseFloat(document.getElementById('contour-min').value) / 100;\r\n            const maxPct = parseFloat(document.getElementById('contour-max').value) / 100;\r\n            const numLevels = parseInt(document.getElementById('contour-levels').value);\r\n\r\n            const gridStep = 4;\r\n            const gridWidth = Math.ceil(size.x / gridStep);\r\n            const gridHeight = Math.ceil(size.y / gridStep);\r\n\r\n            if (gridWidth < 2 || gridHeight < 2) return;\r\n\r\n            const density = new Float64Array(gridWidth * gridHeight);\r\n            const kernelRadius = Math.max(1, Math.min(50, Math.ceil(kernelPx / gridStep)));\r\n            const kernelSize = kernelRadius * 2 + 1;\r\n\r\n            const kernel = new Float64Array(kernelSize * kernelSize);\r\n            for (let dy = -kernelRadius; dy <= kernelRadius; dy++) {\r\n                for (let dx = -kernelRadius; dx <= kernelRadius; dx++) {\r\n                    const dist2 = dx * dx + dy * dy;\r\n                    const sigma = Math.max(0.5, kernelRadius / 2);\r\n                    kernel[(dy + kernelRadius) * kernelSize + (dx + kernelRadius)] =\r\n                        Math.exp(-dist2 / (2 * sigma * sigma));\r\n                }\r\n            }\r\n\r\n            globalMapData.forEach(d => {\r\n                const pos = getJitteredPosition(d);\r\n                const pt = map.latLngToContainerPoint([pos.lat, pos.lon]);\r\n                const gx = Math.floor(pt.x / gridStep);\r\n                const gy = Math.floor(pt.y / gridStep);\r\n                const weight = Math.min(d.count, 50);\r\n\r\n                for (let dy = -kernelRadius; dy <= kernelRadius; dy++) {\r\n                    for (let dx = -kernelRadius; dx <= kernelRadius; dx++) {\r\n                        const px = gx + dx;\r\n                        const py = gy + dy;\r\n                        if (px >= 0 && px < gridWidth && py >= 0 && py < gridHeight) {\r\n                            const ki = (dy + kernelRadius) * kernelSize + (dx + kernelRadius);\r\n                            density[py * gridWidth + px] += weight * kernel[ki];\r\n                        }\r\n                    }\r\n                }\r\n            });\r\n\r\n            let maxDensity = 0;\r\n            for (let i = 0; i < density.length; i++) {\r\n                if (density[i] > maxDensity) maxDensity = density[i];\r\n            }\r\n            if (maxDensity === 0) return;\r\n\r\n            const thresholds = [];\r\n            for (let i = 0; i < numLevels; i++) {\r\n                const t = minPct + (maxPct - minPct) * (i / (numLevels - 1 || 1));\r\n                thresholds.push(t * maxDensity);\r\n            }\r\n\r\n            const contourGenerator = d3.contours()\r\n                .size([gridWidth, gridHeight])\r\n                .thresholds(thresholds);\r\n\r\n            const contours = contourGenerator(density);\r\n\r\n            const opacityStep = numLevels > 1 ? 0.4 / (numLevels - 1) : 0;\r\n            contours.forEach((contour, i) => {\r\n                contour.coordinates.forEach(polygon => {\r\n                    polygon.forEach(ring => {\r\n                        const latLngs = ring.map(([gx, gy]) => {\r\n                            const px = gx * gridStep;\r\n                            const py = gy * gridStep;\r\n                            return map.containerPointToLatLng([px, py]);\r\n                        });\r\n\r\n                        const polyline = L.polyline(latLngs, {\r\n                            color: contourColor,\r\n                            weight: 1,\r\n                            opacity: 0.6 - (i * opacityStep),\r\n                            smoothFactor: 1,\r\n                            pane: 'contoursPane'\r\n                        });\r\n                        contourLayer.addLayer(polyline);\r\n                    });\r\n                });\r\n            });\r\n        }\r\n\r\n        let contourDebounceTimer = null;\r\n        function debouncedRebuildContours() {\r\n            if (contourDebounceTimer) clearTimeout(contourDebounceTimer);\r\n            contourDebounceTimer = setTimeout(() => {\r\n                if (document.getElementById('toggle-contours').checked) {\r\n                    rebuildContours();\r\n                }\r\n            }, 150);\r\n        }\r\n\r\n        function createMarkers() {\r\n            markersLayer.clearLayers();\r\n\r\n            const scaleByCount = document.getElementById('toggle-scale-markers').checked;\r\n            const jitterKm = parseFloat(document.getElementById('marker-jitter').value) || 0;\r\n            const fillColor = document.getElementById('marker-color').value;\r\n            const randomFill = document.getElementById('marker-random-fill').checked;\r\n            const showOutline = document.getElementById('marker-outline').checked;\r\n            const outlineColor = document.getElementById('marker-outline-color').value;\r\n            const randomOutline = document.getElementById('marker-random-outline').checked;\r\n\r\n            globalMapData.forEach((d, idx) => {\r\n                const userIndexHash = hashString(String(d.user_index));\r\n                const pos = getJitteredPosition(d);\r\n\r\n                const size = scaleByCount ? Math.max(4, Math.min(15, 4 + Math.sqrt(d.count))) : 2;\r\n                const thisFill = randomFill ? randomColor(userIndexHash) : fillColor;\r\n                const thisOutline = randomOutline ? randomColor(userIndexHash + 100) : outlineColor;\r\n\r\n                const marker = L.circleMarker([pos.lat, pos.lon], {\r\n                    radius: size,\r\n                    fillColor: thisFill,\r\n                    color: showOutline ? thisOutline : thisFill,\r\n                    weight: showOutline ? 1.5 : 0,\r\n                    opacity: 1,\r\n                    fillOpacity: 0.7,\r\n                    pane: 'markersPane'\r\n                });\r\n                marker.bindPopup(`\r\n                    <strong>${d.city}, ${d.country}</strong><br>\r\n                    UserIndex: ${d.user_index}<br>\r\n                    Pings: ${d.count}<br>\r\n                    ISP: ${d.isp}\r\n                    ${jitterKm > 0 ? '<br><em style=\"color:#888; font-size:11px;\">Location jittered ~' + jitterKm + 'km for privacy</em>' : ''}\r\n                `);\r\n                markersLayer.addLayer(marker);\r\n            });\r\n        }\r\n\r\n        function setupMapControls() {\r\n            document.getElementById('toggle-heatmap').addEventListener('change', e => {\r\n                if (e.target.checked) {\r\n                    map.addLayer(heatLayer);\r\n                    setTimeout(() => setHeatmapOpacity(currentOpacity), 50);\r\n                } else {\r\n                    map.removeLayer(heatLayer);\r\n                }\r\n            });\r\n\r\n            document.getElementById('toggle-markers').addEventListener('change', e => {\r\n                if (e.target.checked) map.addLayer(markersLayer);\r\n                else map.removeLayer(markersLayer);\r\n            });\r\n\r\n            document.getElementById('toggle-scale-markers').addEventListener('change', createMarkers);\r\n            document.getElementById('marker-color').addEventListener('input', createMarkers);\r\n            document.getElementById('marker-random-fill').addEventListener('change', createMarkers);\r\n            document.getElementById('marker-outline').addEventListener('change', createMarkers);\r\n            document.getElementById('marker-outline-color').addEventListener('input', createMarkers);\r\n            document.getElementById('marker-random-outline').addEventListener('change', createMarkers);\r\n            document.getElementById('marker-jitter').addEventListener('change', () => {\r\n                createMarkers();\r\n                debouncedRebuildContours();\r\n            });\r\n\r\n            document.getElementById('basemap-select').addEventListener('change', e => {\r\n                if (currentBasemap) map.removeLayer(currentBasemap);\r\n                currentBasemap = basemaps[e.target.value];\r\n                if (currentBasemap) {\r\n                    currentBasemap.addTo(map);\r\n                    currentBasemap.bringToBack();\r\n                }\r\n            });\r\n\r\n            document.getElementById('colormap-select').addEventListener('change', e => {\r\n                currentColormap = e.target.value;\r\n                rebuildHeatmap();\r\n            });\r\n\r\n            document.getElementById('heatmap-opacity').addEventListener('input', e => {\r\n                currentOpacity = parseFloat(e.target.value);\r\n                setHeatmapOpacity(currentOpacity);\r\n            });\r\n\r\n            document.getElementById('toggle-contours').addEventListener('change', e => {\r\n                if (e.target.checked) {\r\n                    rebuildContours();\r\n                    map.addLayer(contourLayer);\r\n                } else {\r\n                    map.removeLayer(contourLayer);\r\n                }\r\n            });\r\n\r\n            document.getElementById('contour-color').addEventListener('input', debouncedRebuildContours);\r\n            document.getElementById('contour-kernel').addEventListener('change', debouncedRebuildContours);\r\n            document.getElementById('contour-min').addEventListener('change', debouncedRebuildContours);\r\n            document.getElementById('contour-max').addEventListener('change', debouncedRebuildContours);\r\n            document.getElementById('contour-levels').addEventListener('change', debouncedRebuildContours);\r\n        }\r\n\r\n        function initCharts(timeSeries, countryData, hourlyData, pingsDistribution) {\r\n            const chartConfig = {\r\n                view: { strokeWidth: 0 },\r\n                background: '#ffffff',\r\n                axis: { labelFontSize: 11, titleFontSize: 12 }\r\n            };\r\n\r\n            // Common Plotly layout settings\r\n            const plotlyLayout = {\r\n                height: 300,\r\n                margin: { l: 50, r: 20, t: 20, b: 50 },\r\n                paper_bgcolor: 'white',\r\n                plot_bgcolor: 'white',\r\n                font: { family: '-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif', size: 11 },\r\n                xaxis: { \r\n                    showgrid: true, \r\n                    gridcolor: '#eee',\r\n                    tickformat: '%b %Y'\r\n                },\r\n                yaxis: { showgrid: true, gridcolor: '#eee' },\r\n                hovermode: 'x unified'\r\n            };\r\n\r\n            const plotlyConfig = {\r\n                responsive: true,\r\n                displayModeBar: true,\r\n                modeBarButtonsToRemove: ['lasso2d', 'select2d'],\r\n                displaylogo: false\r\n            };\r\n\r\n            // Extract dates and values\r\n            const dates = timeSeries.map(d => d.date);\r\n            const cumulativeUsers = timeSeries.map(d => d.cumulative_users);\r\n            const newUsers = timeSeries.map(d => d.new_users);\r\n            const dailyPings = timeSeries.map(d => d.daily_records);\r\n\r\n            // Compute cumulative pings\r\n            let cumulativePingsTotal = 0;\r\n            const cumulativePings = timeSeries.map(d => {\r\n                cumulativePingsTotal += d.daily_records;\r\n                return cumulativePingsTotal;\r\n            });\r\n\r\n            // === ROW 1: USERS ===\r\n            \r\n            // 1a. Cumulative Users (area chart - fill represents total accumulated)\r\n            Plotly.newPlot('chart-cumulative-users', [{\r\n                x: dates,\r\n                y: cumulativeUsers,\r\n                type: 'scatter',\r\n                mode: 'lines',\r\n                fill: 'tozeroy',\r\n                fillcolor: 'rgba(102, 126, 234, 0.3)',\r\n                line: { color: '#667eea', width: 2 },\r\n                hovertemplate: '<b>%{x|%b %d, %Y}</b><br>Total Users: %{y:,}<extra></extra>'\r\n            }], {\r\n                ...plotlyLayout,\r\n                yaxis: { ...plotlyLayout.yaxis, title: 'Total Users' }\r\n            }, plotlyConfig);\r\n\r\n            // 1b. New Users per Day (daily dots + weekly ± SD + monthly ± SD bands)\r\n            // Compute 30-day (monthly) rolling mean and SD\r\n            const monthlyUsersMean = [];\r\n            const monthlyUsersUpper = [];\r\n            const monthlyUsersLower = [];\r\n            const monthlyUsersDates = [];\r\n            \r\n            for (let i = 29; i < timeSeries.length; i++) {\r\n                const window = [];\r\n                for (let j = i - 29; j <= i; j++) {\r\n                    window.push(timeSeries[j].new_users);\r\n                }\r\n                const mean = window.reduce((a, b) => a + b, 0) / window.length;\r\n                const variance = window.reduce((sum, val) => sum + Math.pow(val - mean, 2), 0) / window.length;\r\n                const sd = Math.sqrt(variance);\r\n                \r\n                monthlyUsersDates.push(timeSeries[i].date);\r\n                monthlyUsersMean.push(Math.round(mean * 10) / 10);\r\n                monthlyUsersUpper.push(Math.round((mean + sd) * 10) / 10);\r\n                monthlyUsersLower.push(Math.max(0, Math.round((mean - sd) * 10) / 10));\r\n            }\r\n\r\n            // Compute 7-day (weekly) rolling mean and SD\r\n            const weeklyUsersMean = [];\r\n            const weeklyUsersUpper = [];\r\n            const weeklyUsersLower = [];\r\n            const weeklyUsersDates = [];\r\n            \r\n            for (let i = 6; i < timeSeries.length; i++) {\r\n                const window = [];\r\n                for (let j = i - 6; j <= i; j++) {\r\n                    window.push(timeSeries[j].new_users);\r\n                }\r\n                const mean = window.reduce((a, b) => a + b, 0) / window.length;\r\n                const variance = window.reduce((sum, val) => sum + Math.pow(val - mean, 2), 0) / window.length;\r\n                const sd = Math.sqrt(variance);\r\n                \r\n                weeklyUsersDates.push(timeSeries[i].date);\r\n                weeklyUsersMean.push(Math.round(mean * 10) / 10);\r\n                weeklyUsersUpper.push(Math.round((mean + sd) * 10) / 10);\r\n                weeklyUsersLower.push(Math.max(0, Math.round((mean - sd) * 10) / 10));\r\n            }\r\n\r\n            Plotly.newPlot('chart-daily-users', [\r\n                // Layer 1: Daily dots (very transparent background)\r\n                {\r\n                    x: dates,\r\n                    y: newUsers,\r\n                    type: 'scatter',\r\n                    mode: 'markers',\r\n                    marker: { color: 'rgba(118, 75, 162, 0.2)', size: 3 },\r\n                    name: 'Daily',\r\n                    hovertemplate: '<b>%{x|%b %d, %Y}</b><br>New Users: %{y}<extra></extra>'\r\n                },\r\n                // Layer 2-3: 30-day (monthly) ± SD band (background)\r\n                {\r\n                    x: monthlyUsersDates,\r\n                    y: monthlyUsersLower,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    line: { color: 'transparent', width: 0 },\r\n                    showlegend: false,\r\n                    hoverinfo: 'skip'\r\n                },\r\n                {\r\n                    x: monthlyUsersDates,\r\n                    y: monthlyUsersUpper,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    fill: 'tonexty',\r\n                    fillcolor: 'rgba(118, 75, 162, 0.15)',\r\n                    line: { color: 'transparent', width: 0 },\r\n                    name: 'Monthly ±SD',\r\n                    hoverinfo: 'skip'\r\n                },\r\n                // Layer 4-5: 7-day (weekly) ± SD band (on top)\r\n                {\r\n                    x: weeklyUsersDates,\r\n                    y: weeklyUsersLower,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    line: { color: 'transparent', width: 0 },\r\n                    showlegend: false,\r\n                    hoverinfo: 'skip'\r\n                },\r\n                {\r\n                    x: weeklyUsersDates,\r\n                    y: weeklyUsersUpper,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    fill: 'tonexty',\r\n                    fillcolor: 'rgba(118, 75, 162, 0.25)',\r\n                    line: { color: 'transparent', width: 0 },\r\n                    name: 'Weekly ±SD',\r\n                    hoverinfo: 'skip'\r\n                },\r\n                // Layer 6: Weekly mean line (thinner)\r\n                {\r\n                    x: weeklyUsersDates,\r\n                    y: weeklyUsersMean,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    line: { color: 'rgba(118, 75, 162, 0.6)', width: 1 },\r\n                    name: '7-Day Avg',\r\n                    hovertemplate: '<b>%{x|%b %d, %Y}</b><br>Weekly: %{y:.1f}<extra></extra>'\r\n                },\r\n                // Layer 7: Monthly mean line (bold)\r\n                {\r\n                    x: monthlyUsersDates,\r\n                    y: monthlyUsersMean,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    line: { color: '#764ba2', width: 2.5 },\r\n                    name: '30-Day Avg',\r\n                    hovertemplate: '<b>%{x|%b %d, %Y}</b><br>Monthly: %{y:.1f}<extra></extra>'\r\n                }\r\n            ], {\r\n                ...plotlyLayout,\r\n                yaxis: { ...plotlyLayout.yaxis, title: 'New Users' },\r\n                showlegend: true,\r\n                legend: { x: 0.01, y: 0.99, bgcolor: 'rgba(255,255,255,0.8)', orientation: 'h' }\r\n            }, plotlyConfig);\r\n\r\n            // === ROW 2: PINGS ===\r\n\r\n            // 2a. Cumulative Pings (area chart - fill represents total accumulated)\r\n            Plotly.newPlot('chart-cumulative-pings', [{\r\n                x: dates,\r\n                y: cumulativePings,\r\n                type: 'scatter',\r\n                mode: 'lines',\r\n                fill: 'tozeroy',\r\n                fillcolor: 'rgba(72, 187, 120, 0.3)',\r\n                line: { color: '#48bb78', width: 2 },\r\n                hovertemplate: '<b>%{x|%b %d, %Y}</b><br>Total Activity: %{y:,}<extra></extra>'\r\n            }], {\r\n                ...plotlyLayout,\r\n                yaxis: { ...plotlyLayout.yaxis, title: 'Total Activity' }\r\n            }, plotlyConfig);\r\n\r\n            // 2b. Daily Activity (daily dots + weekly ± SD + monthly ± SD bands)\r\n            // Compute 30-day (monthly) rolling mean and SD for pings\r\n            const monthlyPingsMean = [];\r\n            const monthlyPingsUpper = [];\r\n            const monthlyPingsLower = [];\r\n            const monthlyPingsDates = [];\r\n            \r\n            for (let i = 29; i < timeSeries.length; i++) {\r\n                const window = [];\r\n                for (let j = i - 29; j <= i; j++) {\r\n                    window.push(timeSeries[j].daily_records);\r\n                }\r\n                const mean = window.reduce((a, b) => a + b, 0) / window.length;\r\n                const variance = window.reduce((sum, val) => sum + Math.pow(val - mean, 2), 0) / window.length;\r\n                const sd = Math.sqrt(variance);\r\n                \r\n                monthlyPingsDates.push(timeSeries[i].date);\r\n                monthlyPingsMean.push(Math.round(mean * 10) / 10);\r\n                monthlyPingsUpper.push(Math.round((mean + sd) * 10) / 10);\r\n                monthlyPingsLower.push(Math.max(0, Math.round((mean - sd) * 10) / 10));\r\n            }\r\n\r\n            // Compute 7-day (weekly) rolling mean and SD for pings\r\n            const weeklyPingsMean = [];\r\n            const weeklyPingsUpper = [];\r\n            const weeklyPingsLower = [];\r\n            const weeklyPingsDates = [];\r\n            \r\n            for (let i = 6; i < timeSeries.length; i++) {\r\n                const window = [];\r\n                for (let j = i - 6; j <= i; j++) {\r\n                    window.push(timeSeries[j].daily_records);\r\n                }\r\n                const mean = window.reduce((a, b) => a + b, 0) / window.length;\r\n                const variance = window.reduce((sum, val) => sum + Math.pow(val - mean, 2), 0) / window.length;\r\n                const sd = Math.sqrt(variance);\r\n                \r\n                weeklyPingsDates.push(timeSeries[i].date);\r\n                weeklyPingsMean.push(Math.round(mean * 10) / 10);\r\n                weeklyPingsUpper.push(Math.round((mean + sd) * 10) / 10);\r\n                weeklyPingsLower.push(Math.max(0, Math.round((mean - sd) * 10) / 10));\r\n            }\r\n\r\n            Plotly.newPlot('chart-daily-pings', [\r\n                // Layer 1: Daily dots (very transparent background)\r\n                {\r\n                    x: dates,\r\n                    y: dailyPings,\r\n                    type: 'scatter',\r\n                    mode: 'markers',\r\n                    marker: { color: 'rgba(72, 187, 120, 0.2)', size: 3 },\r\n                    name: 'Daily',\r\n                    hovertemplate: '<b>%{x|%b %d, %Y}</b><br>Pings: %{y}<extra></extra>'\r\n                },\r\n                // Layer 2-3: 30-day (monthly) ± SD band (background)\r\n                {\r\n                    x: monthlyPingsDates,\r\n                    y: monthlyPingsLower,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    line: { color: 'transparent', width: 0 },\r\n                    showlegend: false,\r\n                    hoverinfo: 'skip'\r\n                },\r\n                {\r\n                    x: monthlyPingsDates,\r\n                    y: monthlyPingsUpper,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    fill: 'tonexty',\r\n                    fillcolor: 'rgba(72, 187, 120, 0.15)',\r\n                    line: { color: 'transparent', width: 0 },\r\n                    name: 'Monthly ±SD',\r\n                    hoverinfo: 'skip'\r\n                },\r\n                // Layer 4-5: 7-day (weekly) ± SD band (on top)\r\n                {\r\n                    x: weeklyPingsDates,\r\n                    y: weeklyPingsLower,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    line: { color: 'transparent', width: 0 },\r\n                    showlegend: false,\r\n                    hoverinfo: 'skip'\r\n                },\r\n                {\r\n                    x: weeklyPingsDates,\r\n                    y: weeklyPingsUpper,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    fill: 'tonexty',\r\n                    fillcolor: 'rgba(72, 187, 120, 0.25)',\r\n                    line: { color: 'transparent', width: 0 },\r\n                    name: 'Weekly ±SD',\r\n                    hoverinfo: 'skip'\r\n                },\r\n                // Layer 6: Weekly mean line (thinner)\r\n                {\r\n                    x: weeklyPingsDates,\r\n                    y: weeklyPingsMean,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    line: { color: 'rgba(72, 187, 120, 0.6)', width: 1 },\r\n                    name: '7-Day Avg',\r\n                    hovertemplate: '<b>%{x|%b %d, %Y}</b><br>Weekly: %{y:.1f}<extra></extra>'\r\n                },\r\n                // Layer 7: Monthly mean line (bold)\r\n                {\r\n                    x: monthlyPingsDates,\r\n                    y: monthlyPingsMean,\r\n                    type: 'scatter',\r\n                    mode: 'lines',\r\n                    line: { color: '#48bb78', width: 2.5 },\r\n                    name: '30-Day Avg',\r\n                    hovertemplate: '<b>%{x|%b %d, %Y}</b><br>Monthly: %{y:.1f}<extra></extra>'\r\n                }\r\n            ], {\r\n                ...plotlyLayout,\r\n                yaxis: { ...plotlyLayout.yaxis, title: 'Pings' },\r\n                showlegend: true,\r\n                legend: { x: 0.01, y: 0.99, bgcolor: 'rgba(255,255,255,0.8)', orientation: 'h' }\r\n            }, plotlyConfig);\r\n\r\n            // === ROW 3: ENGAGEMENT ===\r\n\r\n            // 3a. Pings per user distribution - colored by engagement tier\r\n            // Tier colors: Explorer (gray), Casual (green), Regular (blue), Power (orange), SuperFan (red)\r\n            const tierColors = {\r\n                explorer: '#a0aec0',  // 1 ping - but we filter these out\r\n                casual: '#68d391',    // 2-3 pings\r\n                regular: '#4299e1',   // 4-10 pings\r\n                power: '#ed8936',     // 11-50 pings\r\n                superfan: '#e53e3e'   // 50+ pings\r\n            };\r\n\r\n            function getTierColor(pings) {\r\n                if (pings <= 1) return tierColors.explorer;\r\n                if (pings <= 3) return tierColors.casual;\r\n                if (pings <= 10) return tierColors.regular;\r\n                if (pings <= 50) return tierColors.power;\r\n                return tierColors.superfan;\r\n            }\r\n\r\n            function getTierName(pings) {\r\n                if (pings <= 1) return 'Explorer';\r\n                if (pings <= 3) return 'Casual';\r\n                if (pings <= 10) return 'Regular';\r\n                if (pings <= 50) return 'Power User';\r\n                return 'Super Fan';\r\n            }\r\n\r\n            if (pingsDistribution && pingsDistribution.length > 0) {\r\n                const filteredDistribution = pingsDistribution\r\n                    .filter(d => d.pings > 1)\r\n                    .sort((a, b) => a.pings - b.pings);\r\n                \r\n                if (filteredDistribution.length > 0) {\r\n                    const colors = filteredDistribution.map(d => getTierColor(d.pings));\r\n                    const tierNames = filteredDistribution.map(d => getTierName(d.pings));\r\n\r\n                    Plotly.newPlot('chart-pings-distribution', [{\r\n                        x: filteredDistribution.map(d => d.pings),\r\n                        y: filteredDistribution.map(d => d.users),\r\n                        type: 'scatter',\r\n                        mode: 'markers',\r\n                        marker: { \r\n                            color: colors, \r\n                            size: 10,\r\n                            opacity: 0.8\r\n                        },\r\n                        text: tierNames,\r\n                        hovertemplate: '<b>%{x} times</b><br>%{y} users<br>Category: %{text}<extra></extra>'\r\n                    }], {\r\n                        ...plotlyLayout,\r\n                        xaxis: { \r\n                            type: 'log', \r\n                            title: 'Times Checked In',\r\n                            showgrid: true,\r\n                            gridcolor: '#eee',\r\n                            tickvals: [2, 5, 10, 20, 50, 100, 200, 500, 1000],\r\n                            ticktext: ['2', '5', '10', '20', '50', '100', '200', '500', '1000']\r\n                        },\r\n                        yaxis: { \r\n                            type: 'log', \r\n                            title: 'Number of Users',\r\n                            showgrid: true,\r\n                            gridcolor: '#eee',\r\n                            tickvals: [1, 2, 5, 10, 20, 50, 100, 200, 500, 1000, 2000],\r\n                            ticktext: ['1', '2', '5', '10', '20', '50', '100', '200', '500', '1k', '2k']\r\n                        },\r\n                        hovermode: 'closest'\r\n                    }, plotlyConfig);\r\n                } else {\r\n                    document.getElementById('chart-pings-distribution').innerHTML = '<p style=\"color: #888; text-align: center; padding-top: 100px;\">No repeat users found.</p>';\r\n                }\r\n            } else {\r\n                document.getElementById('chart-pings-distribution').innerHTML = '<p style=\"color: #888; text-align: center; padding-top: 100px;\">No distribution data available. Regenerate data.json.</p>';\r\n            }\r\n\r\n            vegaEmbed('#chart-hourly', {\r\n                $schema: 'https://vega.github.io/schema/vega-lite/v5.json',\r\n                data: { values: hourlyData },\r\n                mark: { type: 'bar', color: '#ed8936' },\r\n                encoding: {\r\n                    x: { field: 'hour', type: 'ordinal', title: 'Hour (UTC)' },\r\n                    y: { field: 'count', type: 'quantitative', title: 'Pings' },\r\n                    tooltip: [\r\n                        { field: 'hour', type: 'ordinal', title: 'Hour' },\r\n                        { field: 'count', type: 'quantitative', title: 'Pings' }\r\n                    ]\r\n                },\r\n                width: 'container',\r\n                height: 230,\r\n                config: chartConfig\r\n            }, { actions: false });\r\n\r\n            // Engagement Tiers: Categorize users by ping count\r\n            const tierCounts = { explorer: 0, casual: 0, regular: 0, power: 0, superfan: 0 };\r\n            if (pingsDistribution && pingsDistribution.length > 0) {\r\n                pingsDistribution.forEach(d => {\r\n                    if (d.pings === 1) tierCounts.explorer += d.users;\r\n                    else if (d.pings <= 3) tierCounts.casual += d.users;\r\n                    else if (d.pings <= 10) tierCounts.regular += d.users;\r\n                    else if (d.pings <= 50) tierCounts.power += d.users;\r\n                    else tierCounts.superfan += d.users;\r\n                });\r\n            }\r\n\r\n            // Define tiers with fixed colors, then sort by user count for display\r\n            const totalTierUsers = tierCounts.explorer + tierCounts.casual + tierCounts.regular + tierCounts.power + tierCounts.superfan;\r\n            const tierData = [\r\n                { tier: '\uD83D\uDD0D Tried Once', users: tierCounts.explorer, color: '#a0aec0', pct: (tierCounts.explorer / totalTierUsers * 100).toFixed(1) + '%' },\r\n                { tier: '\uD83D\uDC4B Came Back (2-3×)', users: tierCounts.casual, color: '#68d391', pct: (tierCounts.casual / totalTierUsers * 100).toFixed(1) + '%' },\r\n                { tier: '⭐ Regular (4-10×)', users: tierCounts.regular, color: '#4299e1', pct: (tierCounts.regular / totalTierUsers * 100).toFixed(1) + '%' },\r\n                { tier: '\uD83D\uDD25 Power User (11-50×)', users: tierCounts.power, color: '#ed8936', pct: (tierCounts.power / totalTierUsers * 100).toFixed(1) + '%' },\r\n                { tier: '\uD83C\uDFC6 Super Fan (50+×)', users: tierCounts.superfan, color: '#e53e3e', pct: (tierCounts.superfan / totalTierUsers * 100).toFixed(1) + '%' }\r\n            ].sort((a, b) => b.users - a.users);\r\n\r\n            vegaEmbed('#chart-engagement-tiers', {\r\n                $schema: 'https://vega.github.io/schema/vega-lite/v5.json',\r\n                data: { values: tierData },\r\n                mark: { type: 'arc', innerRadius: 60 },\r\n                encoding: {\r\n                    theta: { field: 'users', type: 'quantitative', sort: { field: 'users', order: 'descending' } },\r\n                    color: { \r\n                        field: 'tier', \r\n                        type: 'nominal',\r\n                        scale: { \r\n                            domain: tierData.map(t => t.tier),\r\n                            range: tierData.map(t => t.color)\r\n                        },\r\n                        legend: { title: null, orient: 'bottom', columns: 2, labelLimit: 200 }\r\n                    },\r\n                    order: { field: 'users', type: 'quantitative', sort: 'descending' },\r\n                    tooltip: [\r\n                        { field: 'tier', title: 'Tier' },\r\n                        { field: 'users', title: 'Users', format: ',' },\r\n                        { field: 'pct', title: 'Percentage', format: '' }\r\n                    ]\r\n                },\r\n                width: 'container',\r\n                height: 200,\r\n                config: chartConfig\r\n            }, { actions: false });\r\n\r\n            // Day of Week Distribution\r\n            const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];\r\n            const dowCounts = [0, 0, 0, 0, 0, 0, 0];\r\n            timeSeries.forEach(d => {\r\n                const date = new Date(d.date);\r\n                const dow = date.getDay();\r\n                dowCounts[dow] += d.daily_records;\r\n            });\r\n\r\n            const dowData = dayNames.map((name, i) => ({\r\n                day: name,\r\n                pings: dowCounts[i],\r\n                order: i === 0 ? 7 : i  // Put Sunday last\r\n            }));\r\n\r\n            vegaEmbed('#chart-day-of-week', {\r\n                $schema: 'https://vega.github.io/schema/vega-lite/v5.json',\r\n                data: { values: dowData },\r\n                mark: { type: 'bar', color: '#38b2ac', cornerRadiusTopLeft: 4, cornerRadiusTopRight: 4 },\r\n                encoding: {\r\n                    x: { field: 'day', type: 'nominal', sort: { field: 'order' }, title: null },\r\n                    y: { field: 'pings', type: 'quantitative', title: 'Total Activity' },\r\n                    tooltip: [\r\n                        { field: 'day', title: 'Day' },\r\n                        { field: 'pings', title: 'Pings', format: ',' }\r\n                    ]\r\n                },\r\n                width: 'container',\r\n                height: 230,\r\n                config: chartConfig\r\n            }, { actions: false });\r\n\r\n            // Country data now comes pre-computed from Python with population data\r\n            // Store globally for filtering\r\n            window.countryDataRaw = {\r\n                byUsers: countryData.by_users,\r\n                byPerCapita: countryData.by_per_capita,\r\n                byDensity: countryData.by_density\r\n            };\r\n\r\n            // Render country charts with current filter settings\r\n            renderCountryCharts();\r\n\r\n            // Set up filter event listeners\r\n            document.getElementById('country-search').addEventListener('input', renderCountryCharts);\r\n            document.getElementById('min-population').addEventListener('input', renderCountryCharts);\r\n            document.getElementById('min-area').addEventListener('input', renderCountryCharts);\r\n            document.getElementById('reset-filters').addEventListener('click', () => {\r\n                document.getElementById('country-search').value = '';\r\n                document.getElementById('min-population').value = '0';\r\n                document.getElementById('min-area').value = '0';\r\n                renderCountryCharts();\r\n            });\r\n        }\r\n\r\n        // Store Vega views for cross-chart hover synchronization\r\n        window.countryChartViews = {\r\n            absolute: null,\r\n            perCapita: null,\r\n            density: null\r\n        };\r\n        window.hoveredCountry = null;\r\n\r\n        // Function to broadcast hover state to all charts\r\n        function broadcastCountryHover(country) {\r\n            window.hoveredCountry = country;\r\n            const views = window.countryChartViews;\r\n            if (views.absolute) {\r\n                views.absolute.signal('externalHover', country).run();\r\n            }\r\n            if (views.perCapita) {\r\n                views.perCapita.signal('externalHover', country).run();\r\n            }\r\n            if (views.density) {\r\n                views.density.signal('externalHover', country).run();\r\n            }\r\n        }\r\n\r\n        function renderCountryCharts() {\r\n            const searchTerm = document.getElementById('country-search').value.toLowerCase().trim();\r\n            const minPop = parseFloat(document.getElementById('min-population').value) || 0;\r\n            const minArea = parseFloat(document.getElementById('min-area').value) || 0;  // in hundreds of km²\r\n\r\n            const { byUsers, byPerCapita, byDensity } = window.countryDataRaw;\r\n\r\n            // Determine if a country should be highlighted (search term match)\r\n            function isHighlighted(c) {\r\n                if (!searchTerm) return true;\r\n                return c.country.toLowerCase().includes(searchTerm);\r\n            }\r\n\r\n            // Check if a country passes the min population filter (for per-capita chart)\r\n            function passesMinPop(c) {\r\n                return c.population_millions === null || c.population_millions >= minPop;\r\n            }\r\n\r\n            // Check if a country passes the min area filter (in thousand of km²)\r\n            function passesMinArea(c) {\r\n                return c.area_km2 === null || c.area_km2 === undefined || c.area_km2 >= (minArea * 100);\r\n            }\r\n\r\n            // Add highlight field to data\r\n            const byUsersWithHighlight = byUsers.map(c => ({\r\n                ...c,\r\n                highlighted: isHighlighted(c)\r\n            }));\r\n\r\n            const byPerCapitaWithHighlight = byPerCapita\r\n                .filter(c => passesMinPop(c) && passesMinArea(c))\r\n                .map(c => ({\r\n                    ...c,\r\n                    highlighted: isHighlighted(c)\r\n                }));\r\n\r\n            const byDensityWithHighlight = byDensity\r\n                .filter(c => passesMinPop(c) && passesMinArea(c))\r\n                .map(c => ({\r\n                    ...c,\r\n                    highlighted: isHighlighted(c)\r\n                }));\r\n\r\n            // Count highlighted\r\n            const highlightedAbsolute = byUsersWithHighlight.filter(c => c.highlighted).length;\r\n            const highlightedPerCapita = byPerCapitaWithHighlight.filter(c => c.highlighted).length;\r\n            const highlightedDensity = byDensityWithHighlight.filter(c => c.highlighted).length;\r\n            const hasActiveSearch = searchTerm.length > 0;\r\n\r\n            // Update count badges\r\n            document.getElementById('countries-count-absolute').textContent = \r\n                hasActiveSearch ? `(${highlightedAbsolute} highlighted)` : `(${byUsers.length})`;\r\n            document.getElementById('countries-count-percapita').textContent = \r\n                hasActiveSearch \r\n                    ? `(${highlightedPerCapita} highlighted of ${byPerCapitaWithHighlight.length})` \r\n                    : `(${byPerCapitaWithHighlight.length})`;\r\n            document.getElementById('countries-count-density').textContent = \r\n                hasActiveSearch \r\n                    ? `(${highlightedDensity} highlighted of ${byDensityWithHighlight.length})` \r\n                    : `(${byDensityWithHighlight.length})`;\r\n\r\n            // Update highlight summary\r\n            document.getElementById('highlight-summary').textContent = \r\n                searchTerm ? `Highlighting countries matching: \"${searchTerm}\"` : '';\r\n\r\n            // Dynamic heights based on number of countries (18px per row)\r\n            const absoluteChartHeight = Math.max(300, byUsersWithHighlight.length * 18);\r\n            const perCapitaChartHeight = Math.max(300, byPerCapitaWithHighlight.length * 18);\r\n            const densityChartHeight = Math.max(300, byDensityWithHighlight.length * 18);\r\n\r\n            const chartConfig = {\r\n                font: 'system-ui, -apple-system, sans-serif',\r\n                axis: { labelFontSize: 10, titleFontSize: 11 },\r\n                view: { stroke: null }\r\n            };\r\n\r\n            // Colors for highlighted vs dimmed\r\n            const highlightColor = '#667eea';\r\n            const dimColor = '#d0d0d0';\r\n            const highlightColorGreen = '#48bb78';\r\n            const dimColorGreen = '#c8e6c9';\r\n            const highlightColorOrange = '#ed8936';\r\n            const dimColorOrange = '#ffd4a8';\r\n            \r\n            // Hover colors (brighter versions)\r\n            const hoverColor = '#4c5bd4';\r\n            const hoverColorGreen = '#38a169';\r\n            const hoverColorOrange = '#dd6b20';\r\n            const hoverDimColor = '#b0b0b0';\r\n\r\n            // Helper to set up hover event listeners on a view\r\n            function setupHoverListeners(view) {\r\n                view.addEventListener('mouseover', (event, item) => {\r\n                    if (item && item.datum && item.datum.country) {\r\n                        broadcastCountryHover(item.datum.country);\r\n                    }\r\n                });\r\n                view.addEventListener('mouseout', (event, item) => {\r\n                    broadcastCountryHover(null);\r\n                });\r\n            }\r\n\r\n            // Spec for the absolute users chart\r\n            const absoluteSpec = {\r\n                $schema: 'https://vega.github.io/schema/vega-lite/v5.json',\r\n                data: { values: byUsersWithHighlight },\r\n                params: [\r\n                    { name: 'externalHover', value: null }\r\n                ],\r\n                layer: [\r\n                    {\r\n                        mark: { type: 'bar', cursor: 'pointer' },\r\n                        encoding: {\r\n                            y: { field: 'country', type: 'nominal', sort: { field: 'users', order: 'descending' }, title: null },\r\n                            x: { field: 'users', type: 'quantitative', title: 'Users' },\r\n                            fill: {\r\n                                condition: [\r\n                                    { test: 'externalHover && datum.country === externalHover', value: hoverColor },\r\n                                    { test: 'externalHover && datum.country !== externalHover', value: hoverDimColor },\r\n                                    { test: 'datum.highlighted', value: highlightColor }\r\n                                ],\r\n                                value: hasActiveSearch ? dimColor : highlightColor\r\n                            },\r\n                            fillOpacity: {\r\n                                condition: { test: 'externalHover && datum.country !== externalHover', value: 0.4 },\r\n                                value: 1\r\n                            },\r\n                            tooltip: [\r\n                                { field: 'country', type: 'nominal', title: 'Country' },\r\n                                { field: 'users', type: 'quantitative', title: 'Users' },\r\n                                { field: 'region', type: 'nominal', title: 'Region' },\r\n                                { field: 'population_millions', type: 'quantitative', title: 'Population (M)', format: '.1f' },\r\n                                { field: 'users_per_million', type: 'quantitative', title: 'Per Million', format: '.2f' }\r\n                            ]\r\n                        }\r\n                    },\r\n                    {\r\n                        mark: { type: 'text', align: 'left', dx: 3, fontSize: 9 },\r\n                        encoding: {\r\n                            y: { field: 'country', type: 'nominal', sort: { field: 'users', order: 'descending' } },\r\n                            x: { field: 'users', type: 'quantitative' },\r\n                            text: { field: 'users', type: 'quantitative' },\r\n                            fill: {\r\n                                condition: [\r\n                                    { test: 'externalHover && datum.country === externalHover', value: '#000' },\r\n                                    { test: 'externalHover && datum.country !== externalHover', value: '#bbb' },\r\n                                    { test: 'datum.highlighted', value: '#333' }\r\n                                ],\r\n                                value: hasActiveSearch ? '#999' : '#333'\r\n                            }\r\n                        }\r\n                    }\r\n                ],\r\n                width: 'container',\r\n                height: absoluteChartHeight,\r\n                config: chartConfig\r\n            };\r\n\r\n            // Spec for the per-capita chart\r\n            const perCapitaSpec = {\r\n                $schema: 'https://vega.github.io/schema/vega-lite/v5.json',\r\n                data: { values: byPerCapitaWithHighlight },\r\n                params: [\r\n                    { name: 'externalHover', value: null }\r\n                ],\r\n                layer: [\r\n                    {\r\n                        mark: { type: 'bar', cursor: 'pointer' },\r\n                        encoding: {\r\n                            y: { \r\n                                field: 'country', \r\n                                type: 'nominal', \r\n                                sort: { field: 'users_per_million', order: 'descending' },\r\n                                title: null \r\n                            },\r\n                            x: { field: 'users_per_million', type: 'quantitative', title: 'Per Million' },\r\n                            fill: {\r\n                                condition: [\r\n                                    { test: 'externalHover && datum.country === externalHover', value: hoverColorGreen },\r\n                                    { test: 'externalHover && datum.country !== externalHover', value: hoverDimColor },\r\n                                    { test: 'datum.highlighted', value: highlightColorGreen }\r\n                                ],\r\n                                value: hasActiveSearch ? dimColorGreen : highlightColorGreen\r\n                            },\r\n                            fillOpacity: {\r\n                                condition: { test: 'externalHover && datum.country !== externalHover', value: 0.4 },\r\n                                value: 1\r\n                            },\r\n                            tooltip: [\r\n                                { field: 'country', type: 'nominal', title: 'Country' },\r\n                                { field: 'users_per_million', type: 'quantitative', title: 'Per Million', format: '.2f' },\r\n                                { field: 'users', type: 'quantitative', title: 'Total Users' },\r\n                                { field: 'region', type: 'nominal', title: 'Region' },\r\n                                { field: 'population_millions', type: 'quantitative', title: 'Population (M)', format: '.1f' }\r\n                            ]\r\n                        }\r\n                    },\r\n                    {\r\n                        mark: { type: 'text', align: 'left', dx: 3, fontSize: 9 },\r\n                        encoding: {\r\n                            y: { field: 'country', type: 'nominal', sort: { field: 'users_per_million', order: 'descending' } },\r\n                            x: { field: 'users_per_million', type: 'quantitative' },\r\n                            text: { field: 'users_per_million', type: 'quantitative', format: '.1f' },\r\n                            fill: {\r\n                                condition: [\r\n                                    { test: 'externalHover && datum.country === externalHover', value: '#000' },\r\n                                    { test: 'externalHover && datum.country !== externalHover', value: '#bbb' },\r\n                                    { test: 'datum.highlighted', value: '#333' }\r\n                                ],\r\n                                value: hasActiveSearch ? '#999' : '#333'\r\n                            }\r\n                        }\r\n                    }\r\n                ],\r\n                width: 'container',\r\n                height: perCapitaChartHeight,\r\n                config: chartConfig\r\n            };\r\n\r\n            // Spec for the density chart\r\n            const densitySpec = {\r\n                $schema: 'https://vega.github.io/schema/vega-lite/v5.json',\r\n                data: { values: byDensityWithHighlight },\r\n                params: [\r\n                    { name: 'externalHover', value: null }\r\n                ],\r\n                layer: [\r\n                    {\r\n                        mark: { type: 'bar', cursor: 'pointer' },\r\n                        encoding: {\r\n                            y: { \r\n                                field: 'country', \r\n                                type: 'nominal', \r\n                                sort: { field: 'users_per_100k_km2', order: 'descending' },\r\n                                title: null \r\n                            },\r\n                            x: { field: 'users_per_100k_km2', type: 'quantitative', title: 'Per 100k km²' },\r\n                            fill: {\r\n                                condition: [\r\n                                    { test: 'externalHover && datum.country === externalHover', value: hoverColorOrange },\r\n                                    { test: 'externalHover && datum.country !== externalHover', value: hoverDimColor },\r\n                                    { test: 'datum.highlighted', value: highlightColorOrange }\r\n                                ],\r\n                                value: hasActiveSearch ? dimColorOrange : highlightColorOrange\r\n                            },\r\n                            fillOpacity: {\r\n                                condition: { test: 'externalHover && datum.country !== externalHover', value: 0.4 },\r\n                                value: 1\r\n                            },\r\n                            tooltip: [\r\n                                { field: 'country', type: 'nominal', title: 'Country' },\r\n                                { field: 'users_per_100k_km2', type: 'quantitative', title: 'Per 100k km²', format: '.1f' },\r\n                                { field: 'users', type: 'quantitative', title: 'Total Users' },\r\n                                { field: 'region', type: 'nominal', title: 'Region' },\r\n                                { field: 'area_km2', type: 'quantitative', title: 'Area (km²)', format: ',.0f' }\r\n                            ]\r\n                        }\r\n                    },\r\n                    {\r\n                        mark: { type: 'text', align: 'left', dx: 3, fontSize: 9 },\r\n                        encoding: {\r\n                            y: { field: 'country', type: 'nominal', sort: { field: 'users_per_100k_km2', order: 'descending' } },\r\n                            x: { field: 'users_per_100k_km2', type: 'quantitative' },\r\n                            text: { field: 'users_per_100k_km2', type: 'quantitative', format: '.1f' },\r\n                            fill: {\r\n                                condition: [\r\n                                    { test: 'externalHover && datum.country === externalHover', value: '#000' },\r\n                                    { test: 'externalHover && datum.country !== externalHover', value: '#bbb' },\r\n                                    { test: 'datum.highlighted', value: '#333' }\r\n                                ],\r\n                                value: hasActiveSearch ? '#999' : '#333'\r\n                            }\r\n                        }\r\n                    }\r\n                ],\r\n                width: 'container',\r\n                height: densityChartHeight,\r\n                config: chartConfig\r\n            };\r\n\r\n            // Embed all three charts and set up cross-hover\r\n            vegaEmbed('#chart-countries', absoluteSpec, { actions: false }).then(result => {\r\n                window.countryChartViews.absolute = result.view;\r\n                setupHoverListeners(result.view);\r\n            });\r\n\r\n            vegaEmbed('#chart-countries-per-capita', perCapitaSpec, { actions: false }).then(result => {\r\n                window.countryChartViews.perCapita = result.view;\r\n                setupHoverListeners(result.view);\r\n            });\r\n\r\n            vegaEmbed('#chart-countries-density', densitySpec, { actions: false }).then(result => {\r\n                window.countryChartViews.density = result.view;\r\n                setupHoverListeners(result.view);\r\n            });\r\n        }\r\n\r\n        // Initialize on page load\r\n        initDashboard();\r\n    </script>\r\n</body>\r\n</html>
